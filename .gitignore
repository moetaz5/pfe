# Root level ignore
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.log
.DS_Store

# Node.js
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
.env
.env.*

# Build artifacts
**/build/
**/dist/
**/target/
**/out/

# Archives (Most likely the cause of the 408 error)
**/*.zip
**/*.rar
**/*.7z
**/*.tar.gz
**/*.apk
**/*.aab

# Java/Maven/Gradle
**/*.jar
**/*.class
**/.gradle/
**/local.properties

# Flutter specific
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/Generated.xcconfig
**/flutter_export_environment.sh

# Deployment scripts (KEEP THEM but ignore their temporary output)
tmp/
